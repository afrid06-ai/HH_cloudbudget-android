<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_constellation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <include layout="@layout/include_stitch_header" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:lineSpacingMultiplier="1.4"
            android:text="@string/cloud_credentials_blurb"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.08"
            android:text="AWS"
            android:textAllCaps="true"
            android:textColor="@color/tertiary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAwsKey"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_card_soft"
            android:hint="@string/access_key_id"
            android:paddingHorizontal="14dp"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/outline"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.08"
            android:text="Azure"
            android:textAllCaps="true"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAzureTenant"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_card_soft"
            android:hint="@string/tenant_id_hint"
            android:paddingHorizontal="14dp"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/outline"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.08"
            android:text="GCP"
            android:textAllCaps="true"
            android:textColor="@color/secondary_dim"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etGcpProject"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_glass_card_soft"
            android:hint="@string/project_id_hint"
            android:paddingHorizontal="14dp"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/outline"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_gradient_button"
            android:gravity="center"
            android:text="@string/continue_to_app"
            android:textColor="@color/on_primary_container"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnSkipCredentials"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/use_demo_data"
            android:textColor="@color/secondary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
