<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_constellation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <include layout="@layout/include_stitch_header" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:lineSpacingMultiplier="1.4"
            android:text="Connect your cloud accounts to fetch real billing data. Credentials are encrypted end-to-end."
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:padding="12dp"
            android:background="@drawable/bg_glass_card"
            android:textSize="13sp"
            android:gravity="center" />

        <!-- AWS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <View android:layout_width="4dp" android:layout_height="20dp" android:background="@color/aws_orange" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginStart="10dp" android:text="AWS" android:textColor="@color/aws_orange"
                    android:textSize="14sp" android:textStyle="bold" android:letterSpacing="0.08" />
                <TextView android:id="@+id/tvAwsStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Not connected" android:textColor="@color/outline" android:textSize="11sp" />
            </LinearLayout>

            <EditText android:id="@+id/etAwsKey" android:layout_width="match_parent" android:layout_height="48dp"
                android:layout_marginBottom="8dp" android:background="@drawable/bg_surface_container_low"
                android:hint="Access Key ID" android:inputType="textNoSuggestions"
                android:paddingHorizontal="14dp" android:textColor="@color/on_surface" android:textColorHint="@color/outline" android:textSize="14sp" />

            <EditText android:id="@+id/etAwsSecret" android:layout_width="match_parent" android:layout_height="48dp"
                android:layout_marginBottom="8dp" android:background="@drawable/bg_surface_container_low"
                android:hint="Secret Access Key" android:inputType="textPassword"
                android:paddingHorizontal="14dp" android:textColor="@color/on_surface" android:textColorHint="@color/outline" android:textSize="14sp" />

            <EditText android:id="@+id/etAwsRegion" android:layout_width="match_parent" android:layout_height="48dp"
                android:layout_marginBottom="12dp" android:background="@drawable/bg_surface_container_low"
                android:hint="Region (e.g. us-east-1)" android:inputType="textNoSuggestions" android:text="us-east-1"
                android:paddingHorizontal="14dp" android:textColor="@color/on_surface" android:textColorHint="@color/outline" android:textSize="14sp" />

            <TextView android:id="@+id/btnConnectAws" android:layout_width="match_parent" android:layout_height="44dp"
                android:background="@drawable/bg_gradient_button" android:gravity="center"
                android:text="Connect AWS" android:textColor="@color/on_primary_container" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <!-- Azure -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <View android:layout_width="4dp" android:layout_height="20dp" android:background="@color/azure_blue" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginStart="10dp" android:text="AZURE" android:textColor="@color/azure_blue"
                    android:textSize="14sp" android:textStyle="bold" android:letterSpacing="0.08" />
                <TextView android:id="@+id/tvAzureStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Not connected" android:textColor="@color/outline" android:textSize="11sp" />
            </LinearLayout>

            <EditText android:id="@+id/etAzureTenant" android:layout_width="match_parent" android:layout_height="48dp"
                android:layout_marginBottom="8dp" android:background="@drawable/bg_surface_container_low"
                android:hint="Tenant ID" android:inputType="textNoSuggestions"
                android:paddingHorizontal="14dp" android:textColor="@color/on_surface" android:textColorHint="@color/outline" android:textSize="14sp" />

            <EditText android:id="@+id/etAzureClientId" android:layout_width="match_parent" android:layout_height="48dp"
                android:layout_marginBottom="8dp" android:background="@drawable/bg_surface_container_low"
                android:hint="Client ID" android:inputType="textNoSuggestions"
                android:paddingHorizontal="14dp" android:textColor="@color/on_surface" android:textColorHint="@color/outline" android:textSize="14sp" />

            <EditText android:id="@+id/etAzureClientSecret" android:layout_width="match_parent" android:layout_height="48dp"
                android:layout_marginBottom="8dp" android:background="@drawable/bg_surface_container_low"
                android:hint="Client Secret" android:inputType="textPassword"
                android:paddingHorizontal="14dp" android:textColor="@color/on_surface" android:textColorHint="@color/outline" android:textSize="14sp" />

            <EditText android:id="@+id/etAzureSubscription" android:layout_width="match_parent" android:layout_height="48dp"
                android:layout_marginBottom="12dp" android:background="@drawable/bg_surface_container_low"
                android:hint="Subscription ID" android:inputType="textNoSuggestions"
                android:paddingHorizontal="14dp" android:textColor="@color/on_surface" android:textColorHint="@color/outline" android:textSize="14sp" />

            <TextView android:id="@+id/btnConnectAzure" android:layout_width="match_parent" android:layout_height="44dp"
                android:background="@drawable/bg_gradient_button" android:gravity="center"
                android:text="Connect Azure" android:textColor="@color/on_primary_container" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <!-- GCP -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <View android:layout_width="4dp" android:layout_height="20dp" android:background="@color/gcp_green" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginStart="10dp" android:text="GCP" android:textColor="@color/gcp_green"
                    android:textSize="14sp" android:textStyle="bold" android:letterSpacing="0.08" />
                <TextView android:id="@+id/tvGcpStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Not connected" android:textColor="@color/outline" android:textSize="11sp" />
            </LinearLayout>

            <EditText android:id="@+id/etGcpProject" android:layout_width="match_parent" android:layout_height="48dp"
                android:layout_marginBottom="8dp" android:background="@drawable/bg_surface_container_low"
                android:hint="Project ID" android:inputType="textNoSuggestions"
                android:paddingHorizontal="14dp" android:textColor="@color/on_surface" android:textColorHint="@color/outline" android:textSize="14sp" />

            <EditText android:id="@+id/etGcpServiceAccount" android:layout_width="match_parent" android:layout_height="96dp"
                android:layout_marginBottom="12dp" android:background="@drawable/bg_surface_container_low"
                android:gravity="top" android:hint="Paste service account JSON" android:inputType="textMultiLine"
                android:paddingHorizontal="14dp" android:paddingTop="12dp"
                android:textColor="@color/on_surface" android:textColorHint="@color/outline" android:textSize="13sp" />

            <TextView android:id="@+id/btnConnectGcp" android:layout_width="match_parent" android:layout_height="44dp"
                android:background="@drawable/bg_gradient_button" android:gravity="center"
                android:text="Connect GCP" android:textColor="@color/on_primary_container" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <TextView android:id="@+id/btnSyncAll" android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginBottom="12dp" android:background="@drawable/bg_gradient_button" android:gravity="center"
            android:text="Sync All Connected Clouds" android:textColor="@color/on_primary_container" android:textSize="15sp" android:textStyle="bold" />

        <TextView android:id="@+id/btnContinue" android:layout_width="match_parent" android:layout_height="48dp"
            android:layout_marginBottom="8dp" android:background="@drawable/bg_outline_button" android:gravity="center"
            android:text="@string/continue_to_app" android:textColor="@color/primary" android:textSize="14sp" android:textStyle="bold" />

        <TextView android:id="@+id/btnSkipCredentials" android:layout_width="match_parent" android:layout_height="44dp"
            android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true"
            android:gravity="center" android:text="@string/use_demo_data" android:textColor="@color/secondary" android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
