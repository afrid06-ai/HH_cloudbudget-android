<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_constellation"
    android:orientation="vertical"
    android:paddingHorizontal="16dp">

    <include layout="@layout/include_stitch_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/account"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rowProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_glass_card_soft"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="@string/profile"
                android:textColor="@color/on_surface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rowManageClouds"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_glass_card_soft"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="@string/manage_clouds"
                android:textColor="@color/on_surface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rowCloudCredentials"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_glass_card_soft"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="@string/cloud_credentials"
                android:textColor="@color/on_surface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/preferences"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rowNotifications"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_glass_card_soft"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="@string/notification_preferences"
                android:textColor="@color/on_surface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/security"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rowSecurity"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_glass_card_soft"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="@string/security_settings"
                android:textColor="@color/on_surface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="@string/danger_zone"
                android:textColor="@color/error"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rowLogOut"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_danger_button"
                android:gravity="center"
                android:text="@string/log_out"
                android:textColor="@color/error"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
