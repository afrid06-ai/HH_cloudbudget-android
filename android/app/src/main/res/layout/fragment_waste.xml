<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/surface_dim" android:clipToPadding="false" android:paddingBottom="100dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingTop="8dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Waste Detector 🔥" android:textColor="@color/text_headline"
            android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="24dp"/>
        <!-- Hero Waste Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_glass_card_glow"
            android:padding="24dp" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ESTIMATED MONTHLY WASTE" android:textColor="@color/on_surface_variant"
                android:textSize="13sp" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/tvWasteAmount" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="$0.00"
                android:textColor="@color/error" android:textSize="38sp" android:textStyle="bold"
                android:layout_marginTop="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Across AWS, Azure and GCP" android:textColor="@color/on_surface_variant"
                android:textSize="13sp" android:layout_marginTop="4dp"/>
        </LinearLayout>
        <!-- Section Label -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ACTIVE WASTE VECTORS" android:textColor="@color/on_surface_variant"
            android:textSize="14sp" android:letterSpacing="0.05"
            android:layout_marginTop="24dp" android:layout_marginBottom="16dp"/>
        <!-- Dynamic waste cards container -->
        <LinearLayout android:id="@+id/wasteCardsContainer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </LinearLayout>
</ScrollView>
