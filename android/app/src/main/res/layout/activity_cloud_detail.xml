<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_constellation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="32dp">

        <include layout="@layout/include_stitch_header" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_glass_card_glow"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="@string/period_mtd"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCloudSpend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="$0.00"
                android:textColor="@color/tertiary"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCloudSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingMultiplier="1.45"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnOpenConsole"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_outline_button"
            android:gravity="center"
            android:text="@string/open_provider_console"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
