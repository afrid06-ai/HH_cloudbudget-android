<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_constellation"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="-0.03"
            android:text="@string/app_name"
            android:textColor="@color/on_surface"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAuthSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/sign_in_subtitle"
            android:textColor="@color/on_surface_variant"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_glass_card_soft"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:id="@+id/tabAuthMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tabSignIn"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_nav_pill"
                    android:gravity="center"
                    android:text="@string/sign_in"
                    android:textColor="@color/on_primary_container"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tabSignUp"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass_card_soft"
                    android:gravity="center"
                    android:text="@string/sign_up"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/labelName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.08"
                android:text="@string/display_name"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_glass_card_soft"
                android:hint="@string/display_name_hint"
                android:inputType="textPersonName|textCapWords"
                android:paddingHorizontal="14dp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/outline"
                android:textSize="15sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:letterSpacing="0.08"
                android:text="@string/email"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_glass_card_soft"
                android:hint="@string/email_hint"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="14dp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/outline"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:letterSpacing="0.08"
                android:text="@string/password"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_glass_card_soft"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:paddingHorizontal="14dp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/outline"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/labelConfirmPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:letterSpacing="0.08"
                android:text="@string/confirm_password"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_glass_card_soft"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:paddingHorizontal="14dp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/outline"
                android:textSize="15sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnForgot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="12dp"
                android:background="?attr/selectableItemBackground"
                android:padding="8dp"
                android:text="@string/forgot_password"
                android:textColor="@color/primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btnPrimaryAuth"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_gradient_button"
                android:gravity="center"
                android:text="@string/sign_in"
                android:textColor="@color/on_primary_container"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnGoogle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_outline_button"
                android:gravity="center"
                android:text="@string/continue_with_google"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnSkipToApp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card_soft"
            android:gravity="center"
            android:text="@string/skip_to_dashboard"
            android:textColor="@color/secondary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFooterAuth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:padding="12dp"
            android:text="@string/no_account_register"
            android:textColor="@color/primary"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
