<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dim">

    <!-- Center Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <FrameLayout
            android:layout_width="128dp"
            android:layout_height="96dp"
            android:layout_marginBottom="40dp">

            <!-- GCP Green Cloud (Back Right) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☁"
                android:textSize="48sp"
                android:textColor="@color/secondary"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="0dp" />

            <!-- AWS Orange Cloud (Back Left) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☁"
                android:textSize="48sp"
                android:textColor="@color/tertiary"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="0dp" />

            <!-- Azure Blue Cloud (Front Center) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☁"
                android:textSize="64sp"
                android:textColor="@color/primary_fixed"
                android:layout_gravity="center_horizontal|top" />
        </FrameLayout>

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/on_surface"
            android:textSize="40sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.02" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tagline"
            android:textColor="@color/on_surface_variant"
            android:textSize="15sp"
            android:textAlignment="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginTop="12dp" />

        <!-- Progress Bar -->
        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="6dp"
            android:layout_marginTop="64dp"
            android:background="@drawable/bg_progress_track">

            <View
                android:id="@+id/splashProgress"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_progress_fill" />
        </FrameLayout>

        <!-- Status -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/connecting"
            android:textColor="@color/outline"
            android:textSize="12sp"
            android:textStyle="italic"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <!-- Bottom Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/powered_by"
            android:textColor="@color/outline"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- AWS dot -->
            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_onboarding_dot_inactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  AWS     "
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp" />

            <!-- Azure dot -->
            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_onboarding_dot_inactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Azure     "
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp" />

            <!-- GCP dot -->
            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_onboarding_dot_inactive" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  GCP"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
