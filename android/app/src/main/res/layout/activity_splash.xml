<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_constellation">

    <!-- Radial glow behind logo -->
    <View
        android:id="@+id/splashGlow"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_splash_glow"
        android:alpha="0" />

    <!-- Floating particles (programmatic) -->
    <FrameLayout
        android:id="@+id/particleContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Center Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- 3D Cloud Logo Stack -->
        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="120dp"
            android:layout_marginBottom="32dp">

            <!-- GCP Green Cloud (Back Right) -->
            <TextView
                android:id="@+id/cloudGcp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☁"
                android:textSize="52sp"
                android:textColor="@color/secondary"
                android:layout_gravity="end|center_vertical"
                android:alpha="0" />

            <!-- AWS Orange Cloud (Back Left) -->
            <TextView
                android:id="@+id/cloudAws"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☁"
                android:textSize="52sp"
                android:textColor="@color/tertiary"
                android:layout_gravity="start|center_vertical"
                android:alpha="0" />

            <!-- Azure Blue Cloud (Front Center) -->
            <TextView
                android:id="@+id/cloudAzure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☁"
                android:textSize="72sp"
                android:textColor="@color/primary_fixed"
                android:layout_gravity="center_horizontal|top"
                android:alpha="0" />
        </FrameLayout>

        <!-- App Name -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/on_surface"
            android:textSize="42sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.02"
            android:alpha="0" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tagline"
            android:textColor="@color/on_surface_variant"
            android:textSize="15sp"
            android:textAlignment="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginTop="12dp"
            android:alpha="0" />

        <!-- Progress Bar -->
        <FrameLayout
            android:layout_width="180dp"
            android:layout_height="6dp"
            android:layout_marginTop="56dp"
            android:background="@drawable/bg_progress_track">

            <View
                android:id="@+id/splashProgress"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_progress_fill" />
        </FrameLayout>

        <!-- Status with color animation -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/connecting"
            android:textColor="@color/outline"
            android:textSize="12sp"
            android:textStyle="italic"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <!-- Bottom Footer -->
    <LinearLayout
        android:id="@+id/footerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:alpha="0">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/powered_by"
            android:textColor="@color/outline"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/dotAws"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@color/aws_orange" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  AWS     "
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/dotAzure"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@color/primary_fixed" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Azure     "
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/dotGcp"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@color/secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  GCP"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
