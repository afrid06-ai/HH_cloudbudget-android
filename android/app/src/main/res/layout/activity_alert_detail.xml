<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_constellation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="32dp">

        <include layout="@layout/include_stitch_header" />

        <TextView
            android:id="@+id/tvSeverity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_chip_error"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="CRITICAL"
            android:textAllCaps="true"
            android:textColor="@color/error"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAlertTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAlertMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/outline"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvAlertDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:lineSpacingMultiplier="1.5"
            android:textColor="@color/on_surface_variant"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/btnAcknowledge"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_gradient_button"
            android:gravity="center"
            android:text="@string/mark_as_read"
            android:textColor="@color/on_primary_container"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
