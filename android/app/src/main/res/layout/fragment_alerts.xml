<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/surface_dim" android:clipToPadding="false" android:paddingBottom="100dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingTop="8dp">
        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center_vertical" android:layout_marginBottom="20dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Alerts ⚡" android:textColor="@color/text_headline"
                android:textSize="24sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvActiveCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_secondary" android:paddingHorizontal="12dp" android:paddingVertical="6dp"
                android:text="0 ACTIVE" android:textColor="@color/secondary" android:textSize="12sp" android:textStyle="bold"/>
        </LinearLayout>
        <!-- Filter Pills -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="20dp">
            <TextView android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                android:background="@drawable/bg_gradient_button" android:gravity="center"
                android:text="All" android:textColor="@color/on_primary_fixed" android:textSize="13sp" android:textStyle="bold"/>
            <TextView android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                android:layout_marginStart="8dp" android:background="@drawable/bg_surface_container_low" android:gravity="center"
                android:text="AWS" android:textColor="@color/on_surface_variant" android:textSize="13sp"/>
            <TextView android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                android:layout_marginStart="8dp" android:background="@drawable/bg_surface_container_low" android:gravity="center"
                android:text="Azure" android:textColor="@color/on_surface_variant" android:textSize="13sp"/>
            <TextView android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                android:layout_marginStart="8dp" android:background="@drawable/bg_surface_container_low" android:gravity="center"
                android:text="GCP" android:textColor="@color/on_surface_variant" android:textSize="13sp"/>
        </LinearLayout>
        <!-- Dynamic alerts container -->
        <LinearLayout android:id="@+id/alertsContainer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"/>
        <!-- System Status -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="16dp" android:layout_marginBottom="24dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:background="@drawable/bg_glass_card" android:padding="16dp"
                android:layout_marginEnd="6dp" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="OVERALL HEALTH" android:textColor="@color/text_label" android:textSize="10sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="92%" android:textColor="@color/secondary" android:textSize="28sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="System performance" android:textColor="@color/text_label" android:textSize="10sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:background="@drawable/bg_glass_card" android:padding="16dp"
                android:layout_marginStart="6dp" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ACTIVE RULES" android:textColor="@color/text_label" android:textSize="10sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="14" android:textColor="@color/primary" android:textSize="28sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Monitoring online" android:textColor="@color/text_label" android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
