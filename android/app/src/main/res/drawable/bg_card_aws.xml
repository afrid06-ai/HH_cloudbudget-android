<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_fill" />
            <stroke android:width="1dp" android:color="@color/glass_border" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item android:width="4dp" android:gravity="start">
        <shape android:shape="rectangle">
            <solid android:color="@color/aws_orange" />
            <corners android:topLeftRadius="16dp" android:bottomLeftRadius="16dp" />
        </shape>
    </item>
</layer-list>
