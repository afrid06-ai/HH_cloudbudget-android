<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
        </shape>
    </item>
    <!-- Soft nebula glows -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.25"
                android:centerY="0.2"
                android:endColor="@android:color/transparent"
                android:gradientRadius="420dp"
                android:startColor="#1861CDFF"
                android:type="radial" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.75"
                android:centerY="0.75"
                android:endColor="@android:color/transparent"
                android:gradientRadius="380dp"
                android:startColor="#1200FEB1"
                android:type="radial" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.85"
                android:centerY="0.15"
                android:endColor="@android:color/transparent"
                android:gradientRadius="280dp"
                android:startColor="#10FFAC52"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
