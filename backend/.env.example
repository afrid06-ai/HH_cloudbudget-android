# AWS Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Azure Credentials
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id

# GCP Credentials
GCP_PROJECT_ID=your_gcp_project_id
GCP_CREDENTIALS_PATH=path/to/service-account.json

# App Config
USE_MOCK_DATA=true
PORT=8000
DEFAULT_TOTAL_BUDGET=500

# Firebase — service account JSON with Cloud Datastore / Firestore access (Android app reads same project)
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Optional: require this header (X-Sync-Key) on POST /api/sync/* (set for Cloud Scheduler / cron)
# Also used for POST /api/seed/users unless SEED_API_KEY is set
# SYNC_API_KEY=your-random-secret
# SEED_API_KEY=optional-separate-key-for-seed-only

# Hourly Firestore sync in-process (for demos; production use Cloud Scheduler → POST /api/sync/all)
# ENABLE_SCHEDULER=false
# SYNC_INTERVAL_HOURS=1
